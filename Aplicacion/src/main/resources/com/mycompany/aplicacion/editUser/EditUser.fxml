<VBox spacing="16.0" style="-fx-background-color: #E0ff4F;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.aplicacion.editUser.EditUserController">
