                     </children>
                  </VBox>
                  <VBox maxWidth="400.0" minWidth="400.0" prefHeight="200.0" prefWidth="400.0" GridPane.rowIndex="1">
                     <children>
                        <Text fill="#e0ff4f" text="Contraseña" />
                        <PasswordField promptText="Contraseña" />
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </GridPane>
         </children>
      </VBox>
      <Button onAction="#goToHome" prefHeight="26.0" prefWidth="344.0" style="-fx-background-color: #00272B; -fx-background-radius: 15;" text="Iniciar sesión" textFill="#e0ff4f" />
   </children>
   <padding>
      <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
   </padding>
</VBox>
